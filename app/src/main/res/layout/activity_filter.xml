<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"/>

        <!-- Runden -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Runden"
                android:textSize="18sp"/>

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderRounds"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:valueFrom="1"
                android:valueTo="10"
                android:stepSize="1"
                android:value="5"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRoundValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

        <!-- Grundton -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Grundton"
                android:textSize="18sp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBaseTone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvBaseToneMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="fest"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- Intervall min -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intervall min"
            android:textSize="18sp"/>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderIntervalMin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="1"
            android:valueTo="23"
            android:stepSize="1"
            android:value="1"/>

        <TextView
            android:id="@+id/tvIntervalMinValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:layout_gravity="center_horizontal"/>

        <!-- Intervall max -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intervall max"
            android:textSize="18sp"/>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderIntervalMax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="2"
            android:valueTo="24"
            android:stepSize="1"
            android:value="12"/>

        <TextView
            android:id="@+id/tvIntervalMaxValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12"
            android:layout_gravity="center_horizontal"/>

        <!-- Polyphon -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Polyphon"
            android:textSize="18sp"/>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderPolyphony"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="2"
            android:valueTo="4"
            android:stepSize="1"
            android:value="2"/>

        <TextView
            android:id="@+id/tvPolyphonyValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2"
            android:layout_gravity="center_horizontal"/>

        <!-- Nur eigene ID -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="Nur eigene ID"
                android:textSize="18sp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchOwnId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnApply"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Anwenden"
            android:layout_gravity="center_horizontal"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="Abbrechen"
            android:layout_marginTop="12dp"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>

</ScrollView>